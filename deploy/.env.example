# ============================================================
# Infisical 自架部署設定
# 複製此檔案為 .env 並填入實際值
# ============================================================

# --- 必填：加密金鑰（產生方式：openssl rand -hex 16）---
ENCRYPTION_KEY=換成你自己的32位hex字串

# --- 必填：JWT 簽名密鑰（產生方式：openssl rand -base64 32）---
AUTH_SECRET=換成你自己的base64字串

# --- 必填：你的網站網址（Proxmox 上的 IP 或域名）---
SITE_URL=http://YOUR_SERVER_IP

# --- PostgreSQL ---
POSTGRES_USER=infisical
POSTGRES_PASSWORD=換成強密碼
POSTGRES_DB=infisical
DB_CONNECTION_URI=postgres://infisical:換成強密碼@db:5432/infisical

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Mock License（不要動這兩行）---
# 這兩個值由 docker-compose.yml 的 environment 區塊注入，此處僅作說明
# LICENSE_KEY=MOCK-LICENSE-KEY
# LICENSE_SERVER_URL=http://mock-license:3001

# --- Email (可選，不填則停用 email 功能)---
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Infisical
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false

# --- 關閉雲端遙測 ---
TELEMETRY_ENABLED=false
